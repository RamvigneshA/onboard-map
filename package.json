{
  "name": "onboard-map",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "onboard-map": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npm run build:cli",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --external:ts-morph --external:commander --external:picocolors --external:adm-zip",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "tsx test/services/import-graph.test.ts && tsx test/checks/circular-deps.test.ts",
    "start": "node server.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.18",
    "commander": "^15.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "picocolors": "^1.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "ts-morph": "^28.0.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
